<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>House Price WebApp</display-name>

    <servlet>
        <servlet-name>SearchServlet</servlet-name>
        <servlet-class>com.housing.servlet.SearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchServlet</servlet-name>
        <url-pattern>/api/search</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TrendServlet</servlet-name>
        <servlet-class>com.housing.servlet.TrendServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TrendServlet</servlet-name>
        <url-pattern>/api/trend</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PredictServlet</servlet-name>
        <servlet-class>com.housing.servlet.PredictServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PredictServlet</servlet-name>
        <url-pattern>/api/predict</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
